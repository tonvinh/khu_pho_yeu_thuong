# ==== Khu Phố Của Tôi — biến môi trường (KHÔNG commit file .env thật) ====

# --- Domain (Q5): chọn MỘT trong hai phương án, chỉ đổi biến env ---
# Phương án A: khupho.fpt.vn      → BASE_PATH=""            SITE_ORIGIN=https://khupho.fpt.vn
# Phương án B: fpt.vn/khu-pho-de-thuong → BASE_PATH="/khu-pho-de-thuong" SITE_ORIGIN=https://fpt.vn
BASE_PATH=
SITE_ORIGIN=http://localhost
# Địa chỉ Caddy lắng nghe: ':80' cho local, 'khupho.fpt.vn' để tự động TLS
SITE_ADDRESS=:80

# --- Database ---
POSTGRES_USER=khupho
POSTGRES_PASSWORD=doi-mat-khau-nay
POSTGRES_DB=khupho
# Khi chạy ngoài Docker (dev): DATABASE_URL=postgres://khupho:khupho_dev@localhost:5432/khupho
DATABASE_URL=postgres://khupho:doi-mat-khau-nay@db:5432/khupho

# --- Bảo mật định danh (07 §2.1) — 2 khoá TÁCH BIỆT, sinh ngẫu nhiên ≥256-bit ---
# PEPPER: openssl rand -hex 32   (KHÔNG xoay được giữa chừng — chọn kỹ ngay từ đầu)
PHONE_PEPPER=
# Khoá AES-256-GCM (base64 32 byte): openssl rand -base64 32
PHONE_AES_KEY=

# --- MinIO (object storage ảnh) ---
MINIO_ACCESS_KEY=khupho
MINIO_SECRET_KEY=doi-secret-nay-dai-hon
MINIO_BUCKET=khupho
# Khi chạy ngoài Docker (dev): MINIO_ENDPOINT=localhost, MINIO_PORT=9000
# Trong compose các giá trị này bị override thành storage:9000

# --- Seed (tuỳ chọn) ---
# SEED_ADMIN_PASSWORD=KhuPho@2026!Demo
